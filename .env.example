# Copy this file to .env and fill in your values. Never commit .env.
# Get Firebase values from: Firebase Console > Project Settings > Your apps

# API
API_ENDPOINT=https://app.parsa-ai.com.br

# Sentry (release builds only)
SENTRY_DSN=

# Firebase - required for Analytics, Messaging. Get from Firebase Console.
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_ANDROID_API_KEY=
FIREBASE_ANDROID_APP_ID=
FIREBASE_IOS_API_KEY=
FIREBASE_IOS_APP_ID=
FIREBASE_ANDROID_CLIENT_ID=
FIREBASE_IOS_BUNDLE_ID=
